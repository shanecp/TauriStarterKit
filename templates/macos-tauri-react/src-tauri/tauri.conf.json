{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "__APP_NAME__",
  "version": "0.1.0",
  "identifier": "__BUNDLE_ID__",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "__APP_NAME__",
        "width": 1440,
        "height": 930,
        "minWidth": 960,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app",
      "dmg"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ],
    "category": "DeveloperTool",
    "shortDescription": "A macOS Tauri desktop utility app.",
    "longDescription": "__APP_NAME__ provides a reusable shell for safe local machine utilities.",
    "macOS": {
      "minimumSystemVersion": "13.0"
    }
  }
}
